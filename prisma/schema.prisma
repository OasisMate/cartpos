datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Optional: Use direct connection for migrations if needed
  // directUrl = env("DIRECT_URL")
  // Connection pooling is handled via DATABASE_URL parameters:
  // - Use port 6543 for connection pooler (recommended)
  // - Add pgbouncer=true parameter
  // - Set connection_limit=10 (adjust based on your Supabase plan)
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------------------------------
// Core: Organizations, Shops, Users, Settings
// Multi-tenant architecture with role-based access control
// -----------------------------------------------------

// Organization: Top-level entity that owns multiple stores
// Managed by Platform Admins and Org Admins
model Organization {
  id               String          @id @default(cuid())
  name             String
  legalName        String?
  type             OrganizationType
  phone            String?
  city             String?
  addressLine1     String?
  addressLine2     String?
  ntn              String?
  strn             String?
  status           OrgStatus       @default(PENDING)
  // Demo/test fixture org. When true, destructive API actions are blocked org-wide
  // (see lib/demo.ts + route guards); reset via scripts/reset-demo-org.ts.
  isDemo           Boolean         @default(false)
  requestedBy      String?
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  suspensionReason String?
  // Safe deletion: admins schedule a purge; it can only run after a buffer
  // (and is reversible until then). Never set for ACTIVE orgs.
  deletionScheduledAt DateTime?
  deletionScheduledBy String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  shops       Shop[]
  users       OrganizationUser[]
  activityLogs ActivityLog[]

  @@index([name])
  @@index([status])
  @@index([city])
  @@index([type])
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum OrganizationType {
  RETAIL_STORE
  WHOLESALE
  SUPERMARKET
  GENERAL_STORE
  CONVENIENCE_STORE
  KIRYANA_STORE
  PHARMACY
  ELECTRONICS_STORE
  MOBILE_ACCESSORIES
  CLOTHING_STORE
  FOOTWEAR_STORE
  COSMETICS_STORE
  JEWELRY_STORE
  OPTICAL_STORE
  HARDWARE_STORE
  SANITARY_STORE
  AUTO_PARTS
  STATIONERY_STORE
  BAKERY
  RESTAURANT
  FURNITURE_STORE
  OTHER
}

model Shop {
  id          String        @id @default(cuid())
  orgId       String
  name        String
  city        String?
  phone       String?
  addressLine1 String?
  addressLine2 String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  organization Organization  @relation(fields: [orgId], references: [id])
  owners      UserShop[]
  settings    ShopSettings?
  products    Product[]
  suppliers   Supplier[]
  customers   Customer[]
  invoices    Invoice[]
  purchases   Purchase[]
  stockLedger StockLedger[]
  payments    Payment[]
  customerLedger CustomerLedger[]
  supplierLedger SupplierLedger[]
  expenses    Expense[]
  activityLogs ActivityLog[]
  saleReturns SaleReturn[]
  quotations  Quotation[]
  stockLots   StockLot[]
  shifts      Shift[]
  cashMovements CashMovement[]

  @@index([orgId, name])
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  phone     String?     @unique
  cnic      String?     @unique
  isWhatsApp Boolean   @default(false)
  profileImageUrl String? // profile photo stored as a base64 data URL (PNG/JPEG)
  password  String      // hashed password
  role      UserRole    @default(NORMAL)
  emailVerified Boolean  @default(false) // email ownership confirmed via verification link
  twoFactorEnabled Boolean @default(false) // opt-in email 2FA on login
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  shops            UserShop[]
  organizations    OrganizationUser[]
  createdInvoices  Invoice[]   @relation("InvoiceCreatedBy")
  createdPurchases Purchase[]  @relation("PurchaseCreatedBy")
  supplierLedgerEntries SupplierLedger[] @relation("SupplierLedgerCreatedBy")
  notifications    Notification[]
  passwordResets   PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  loginCodes       LoginCode[]
  expenses         Expense[]
  activityLogs     ActivityLog[]
  createdReturns   SaleReturn[]  @relation("SaleReturnCreatedBy")
  createdQuotations Quotation[]  @relation("QuotationCreatedBy")
  receivedPayments Payment[]     @relation("PaymentReceivedBy")
  openedShifts     Shift[]       @relation("ShiftOpenedBy")
  closedShifts     Shift[]       @relation("ShiftClosedBy")
  cashMovements    CashMovement[]

  @@index([phone])
  @@index([cnic])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  code      String?  // 6-digit code; alternative to the reset link
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// Short-lived 6-digit codes for opt-in login 2FA.
model LoginCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  code      String?  // 6-digit code; alternative to clicking the link
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model UserShop {
  id        String    @id @default(cuid())
  userId    String
  shopId    String
  shopRole  ShopRole
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  shop      Shop      @relation(fields: [shopId], references: [id])

  @@unique([userId, shopId])
}

// User role at platform level
enum UserRole {
  PLATFORM_ADMIN  // Full system access, manages all organizations
  NORMAL          // Regular user (role defined at org/shop level)
}

// User role at store level
// STORE_MANAGER: Full store operations (POS, inventory, reports, purchases)
// CASHIER: Limited to POS and personal dashboard
enum ShopRole {
  STORE_MANAGER  // Renamed from SHOP_OWNER (v1.1.0)
  CASHIER
}

// User role at organization level
// Links users to organizations with specific permissions
model OrganizationUser {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  orgRole   OrgRole
  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
}

enum OrgRole {
  ORG_ADMIN
}

model ShopSettings {
  id                              String        @id @default(cuid())
  shopId                          String        @unique
  requireCostPriceForStockItems   Boolean       @default(false)
  requireBarcodeForProducts       Boolean       @default(false)
  allowCustomUnits                Boolean       @default(true)
  allowNegativeStock              Boolean       @default(true)  // Allow sales even if stock is insufficient
  languageMode                    LanguageMode  @default(EN_BILINGUAL)
  printerName                     String?       // Preferred printer name (for reference, actual selection handled by browser)
  autoPrint                       Boolean       @default(false)  // Auto-print receipts after sale completion
  logoUrl                         String?       // Store logo image URL (PNG format)
  receiptHeaderDisplay            ReceiptHeaderDisplay @default(NAME_ONLY)  // What to show on receipt header
  cardFeePercent                  Decimal?      @db.Decimal(5, 2) // Percentage card fee applied on card payments (0 = no fee)
  allowCardFeeOverride            Boolean       @default(false)   // Allow per-sale override of card fee percent
  // Business-type feature flags. Seeded from Organization.type at signup (see lib/domain/business-presets.ts),
  // editable later in store Settings. Defaults preserve pre-feature behaviour for existing shops.
  enableQuotations                Boolean       @default(true)    // Show quotations module (hardware/electric); existing shops keep it on
  enableServiceCharge             Boolean       @default(false)   // Restaurant/hotel service charge at checkout
  serviceChargePercent            Decimal?      @db.Decimal(5, 2) // Default service charge percent (when enabled)
  allowServiceChargeOverride      Boolean       @default(true)    // Allow per-sale override of service charge
  enableDeliveryCharge            Boolean       @default(false)   // Restaurant: add a delivery fee on the bill
  deliveryChargeMode              DeliveryChargeMode @default(FIXED) // Store manager picks fixed amount or % of bill
  deliveryChargeDefault           Decimal?      @db.Decimal(10, 2) // Default delivery fee when mode=FIXED (editable per order)
  deliveryChargePercent           Decimal?      @db.Decimal(5, 2)  // Delivery fee percent when mode=PERCENT
  // When a delivery charge is applied, drop the service charge to 0 by default.
  // Store managers who want both can turn this off (versatile, not a hard rule).
  removeServiceChargeOnDelivery   Boolean       @default(true)
  enableUnitSplitting             Boolean       @default(false)   // Pharmacy: sell whole box or loose unit (reuses cartonSize math)
  // Show the Retail/Trade pricing toggle at POS. Default true preserves existing shops;
  // seeded by preset for new shops (on for hardware/electric/wholesale-type trades).
  enableTradePricing              Boolean       @default(true)
  // Hybrid config bucket: rare / vertical-specific toggles & params that don't warrant a column.
  // Common, frequently-queried flags stay as typed columns above; everything else lives here so
  // adding a vertical never means a migration. Shape is owned by lib/domain/business-presets.ts.
  featureConfig                   Json?
  timezone                        String        @default("Asia/Karachi") // IANA tz used to compute the shop's "today" for dashboards/reports
  // Cash-drawer discipline: when true, a cashier must open a drawer (shift) before selling.
  // Default false preserves existing behaviour — drawers are tracked only when one is open.
  requireOpenDrawer               Boolean       @default(false)
  shop                            Shop          @relation(fields: [shopId], references: [id])
}

enum DeliveryChargeMode {
  FIXED    // flat rupee amount per delivery order
  PERCENT  // percent of the bill
}

enum LanguageMode {
  EN_ONLY
  EN_BILINGUAL    // v1
  URDU_EN         // future
}

enum ReceiptHeaderDisplay {
  NAME_ONLY       // Show only store name
  LOGO_ONLY       // Show only logo
  BOTH            // Show both name and logo
}

// -----------------------------------------------------
// Products & Stock
// -----------------------------------------------------

model Product {
  id           String         @id @default(cuid())
  shopId       String
  name         String
  sku          String?
  barcode      String?
  unit         String
  price        Decimal        @db.Decimal(10, 2)
  tradePrice   Decimal?       @db.Decimal(10, 2)  // Optional wholesale/trade per-unit rate (contractors)
  cartonPrice  Decimal?       @db.Decimal(10, 2)  // Price for full carton
  costPrice    Decimal?       @db.Decimal(10, 2)
  category     String?
  trackStock   Boolean        @default(false)
  reorderLevel Int?
  cartonSize   Int?           // Number of pieces in a carton
  cartonBarcode String?
  archivedAt   DateTime?      // Non-null = hidden from POS/lists/dashboard; history preserved
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  shop         Shop           @relation(fields: [shopId], references: [id])
  invoiceLines InvoiceLine[]
  purchaseLines PurchaseLine[]
  stockLedger  StockLedger[]
  saleReturnLines SaleReturnLine[]
  quotationLines QuotationLine[]
  stockLots    StockLot[]
  packagingLevels PackagingLevel[]

  @@index([shopId, name])
  @@unique([shopId, barcode], map: "unique_barcode_per_shop")
  @@index([shopId, barcode])
}

// -----------------------------------------------------
// Generic reusable models (Phase 2 foundation — used by later verticals).
// One change, many angles: these intentionally serve multiple business types
// instead of adding per-feature columns to Product.
// -----------------------------------------------------

// A tracked lot/unit of a product. Pharmacy: batch no. + expiry + quantity.
// Electronics/mobile: serial/IMEI (quantity 1 each). Perishables: expiry/FEFO.
// Same table, different fields populated per vertical.
model StockLot {
  id          String    @id @default(cuid())
  shopId      String
  productId   String
  lotNo       String?   // batch / lot number (pharmacy, food)
  serial      String?   // serial number / IMEI (electronics) — one unit per row when used
  expiry      DateTime? // expiry date (FEFO ordering)
  quantity    Decimal   @default(0) @db.Decimal(12, 3) // remaining qty in base units
  costPrice   Decimal?  @db.Decimal(12, 2)             // optional per-lot cost
  note        String?
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  shop        Shop      @relation(fields: [shopId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@index([shopId, productId])
  @@index([productId, expiry])
  @@index([shopId, serial])
}

// A packaging/unit level for a product, with a conversion factor to the base unit.
// Replaces ad-hoc cartonSize/cartonPrice growth. Serves carton -> box -> strip -> tablet
// (pharmacy), bundles (hardware), and case-packs (grocery). Base unit has factorToBase = 1.
model PackagingLevel {
  id           String   @id @default(cuid())
  productId    String
  name         String   // e.g. "Carton", "Box", "Strip", "Tablet", "Bundle"
  factorToBase Decimal  @db.Decimal(12, 4) // base units this level equals (base = 1)
  price        Decimal? @db.Decimal(12, 2) // optional price at this level (else derived from base)
  barcode      String?  // optional scan barcode for this level
  level        Int      // 0 = base unit; higher = larger pack
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id])

  @@unique([productId, name])
  @@index([productId, level])
}

model StockLedger {
  id          String         @id @default(cuid())
  shopId      String
  productId   String
  changeQty   Decimal        @db.Decimal(10, 3) // quantity can be fractional
  type        StockMoveType
  refType     String?        // e.g. "purchase_line", "invoice_line", "adjustment"
  refId       String?
  createdAt   DateTime       @default(now())
  shop        Shop           @relation(fields: [shopId], references: [id])
  product     Product        @relation(fields: [productId], references: [id])

  @@index([shopId, productId])
  @@index([shopId, productId, type])
  @@index([shopId, createdAt])
}

enum StockMoveType {
  PURCHASE
  SALE
  ADJUSTMENT
  DAMAGE
  EXPIRY
  RETURN
  SELF_USE
}

// -----------------------------------------------------
// Suppliers & Purchases
// -----------------------------------------------------

model Supplier {
  id        String     @id @default(cuid())
  shopId    String
  name      String
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime   @default(now())
  shop      Shop       @relation(fields: [shopId], references: [id])
  purchases Purchase[]
  ledger    SupplierLedger[]

  @@index([shopId, name])
}

// Supplier payables ledger (what the shop OWES each supplier).
// Mirror of CustomerLedger. Balance owed = sum(CREDIT) − sum(DEBIT).
//   PURCHASE_CREDIT / OPENING_BALANCE => CREDIT (payable goes up)
//   PAYMENT_MADE                      => DEBIT  (payable goes down)
//   ADJUSTMENT                        => either direction
model SupplierLedger {
  id              String            @id @default(cuid())
  shopId          String
  supplierId      String
  type            SupplierEntryType
  direction       LedgerDirection
  amount          Decimal           @db.Decimal(10, 2)
  method          PaymentMethod?    // set for PAYMENT_MADE
  note            String?
  refType         String?           // e.g. PURCHASE
  refId           String?           // e.g. purchase id
  createdByUserId String?
  /// Cash drawer (shift) a cash PAYMENT_MADE was paid from, if one was open when recorded.
  shiftId         String?
  createdAt       DateTime          @default(now())
  shop            Shop              @relation(fields: [shopId], references: [id])
  supplier        Supplier          @relation(fields: [supplierId], references: [id])
  createdBy       User?             @relation("SupplierLedgerCreatedBy", fields: [createdByUserId], references: [id])
  shift           Shift?            @relation(fields: [shiftId], references: [id])

  @@index([shopId])
  @@index([supplierId])
  @@index([supplierId, createdAt])
  @@index([shopId, supplierId])
  @@index([shiftId])
}

enum SupplierEntryType {
  PURCHASE_CREDIT   // bought on credit — payable increases
  PAYMENT_MADE      // paid the supplier — payable decreases
  OPENING_BALANCE   // initial amount already owed when supplier added
  ADJUSTMENT
}

model Purchase {
  id              String         @id @default(cuid())
  shopId          String
  supplierId      String?
  date            DateTime       @default(now())
  reference       String?
  notes           String?
  /// Offline client id — dedupes purchases created offline so re-sync can't duplicate them.
  clientId        String?
  createdByUserId String?
  createdAt       DateTime       @default(now())
  shop            Shop           @relation(fields: [shopId], references: [id])
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  lines           PurchaseLine[]
  createdBy       User?          @relation("PurchaseCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([shopId, clientId])
  @@index([shopId, date])
}

model PurchaseLine {
  id          String          @id @default(cuid())
  purchaseId  String
  productId   String
  quantity    Decimal         @db.Decimal(10, 3)
  unitCost    Decimal?        @db.Decimal(10, 2)
  createdAt   DateTime        @default(now())
  purchase    Purchase        @relation(fields: [purchaseId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])

  @@index([purchaseId])
}

// -----------------------------------------------------
// Customers & Udhaar
// -----------------------------------------------------

model Customer {
  id        String           @id @default(cuid())
  shopId    String
  name      String
  phone     String?
  notes     String?
  /// Offline client id — dedupes customers created offline so re-sync can't duplicate them.
  clientId  String?
  createdAt DateTime         @default(now())
  shop      Shop             @relation(fields: [shopId], references: [id])
  invoices  Invoice[]
  ledger    CustomerLedger[]
  payments  Payment[]
  saleReturns SaleReturn[]
  quotations Quotation[]

  @@unique([shopId, clientId])
  @@index([shopId, name])
  @@index([shopId, phone])
}

model CustomerLedger {
  id          String             @id @default(cuid())
  shopId      String
  customerId  String
  type        CustomerEntryType
  direction   LedgerDirection
  amount      Decimal            @db.Decimal(10, 2)
  refType     String?
  refId       String?
  createdAt   DateTime           @default(now())
  shop        Shop               @relation(fields: [shopId], references: [id])
  customer    Customer           @relation(fields: [customerId], references: [id])

  @@index([shopId])
  @@index([customerId])
  @@index([customerId, createdAt])
  @@index([shopId, customerId])
}

enum CustomerEntryType {
  SALE_UDHAAR
  PAYMENT_RECEIVED
  ADJUSTMENT
}

enum LedgerDirection {
  DEBIT   // customer owes more
  CREDIT  // owes less
}

// -----------------------------------------------------
// Sales, Invoices, Payments
// -----------------------------------------------------

model Invoice {
  id              String          @id @default(cuid())
  shopId          String
  customerId      String?
  number          String?         // human-readable invoice no., optional
  /// Set from POS offline client id (cuid) so duplicate sync paths cannot double-post the same sale
  clientSaleId    String?
  status          InvoiceStatus   @default(COMPLETED)
  paymentStatus   PaymentStatus
  paymentMethod   PaymentMethod?  // null for UDHAAR
  subtotal        Decimal         @db.Decimal(10, 2)
  discount        Decimal         @default(0) @db.Decimal(10, 2)
  // Extra charges added on top of (subtotal - discount). Card fee remains implicit
  // in total; receipt derives it as total - (subtotal - discount) - serviceCharge - deliveryCharge.
  serviceCharge   Decimal         @default(0) @db.Decimal(10, 2)
  deliveryCharge  Decimal         @default(0) @db.Decimal(10, 2)
  total           Decimal         @db.Decimal(10, 2)
  createdByUserId String?
  createdAt       DateTime        @default(now())
  shop            Shop            @relation(fields: [shopId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  lines           InvoiceLine[]
  payments        Payment[]
  createdBy       User?           @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  returns         SaleReturn[]

  @@unique([shopId, clientSaleId])
  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([shopId, paymentStatus])
  @@index([shopId, paymentStatus, createdAt])
}

enum QuotationStatus {
  OPEN
  CONVERTED
  CANCELLED
}

/// Pre-sale estimate/quotation. Holds no stock or money until converted to a sale.
model Quotation {
  id              String          @id @default(cuid())
  shopId          String
  customerId      String?
  customerName    String?         // free-text (e.g. a company not in the customer list)
  number          String?         // human-readable quote no., e.g. Q000001
  status          QuotationStatus @default(OPEN)
  subtotal        Decimal         @db.Decimal(10, 2)
  discount        Decimal         @default(0) @db.Decimal(10, 2)
  total           Decimal         @db.Decimal(10, 2)
  validUntil      DateTime?
  note            String?
  convertedInvoiceId String?      // set when converted (plain reference; no FK)
  convertedAt     DateTime?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  shop            Shop            @relation(fields: [shopId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  createdBy       User?           @relation("QuotationCreatedBy", fields: [createdByUserId], references: [id])
  lines           QuotationLine[]

  @@index([shopId, createdAt])
  @@index([shopId, status])
}

model QuotationLine {
  id          String    @id @default(cuid())
  quotationId String
  productId   String
  quantity    Decimal   @db.Decimal(10, 3)
  unitPrice   Decimal   @db.Decimal(10, 2)
  lineTotal   Decimal   @db.Decimal(10, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])

  @@index([quotationId])
}

model InvoiceLine {
  id          String     @id @default(cuid())
  invoiceId   String
  productId   String
  quantity    Decimal    @db.Decimal(10, 3)
  unitPrice   Decimal    @db.Decimal(10, 2)
  lineTotal   Decimal    @db.Decimal(10, 2)
  /// Base units per sold item (1 = loose, cartonSize for a carton, or a PackagingLevel factor).
  /// Stock deducts quantity * unitsPerItem; persisted so edits/voids reverse the right base units.
  unitsPerItem Decimal   @default(1) @db.Decimal(10, 3)
  /// Packaging label the item was sold as (e.g. "Carton", "Box"); null = base unit.
  packName    String?
  createdAt   DateTime   @default(now())
  invoice     Invoice     @relation(fields: [invoiceId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

/// A return / refund / exchange against an original sale (credit note).
model SaleReturn {
  id                String          @id @default(cuid())
  shopId            String
  originalInvoiceId String
  customerId        String?
  kind              SaleReturnKind  @default(REFUND)        // REFUND or EXCHANGE
  returnTotal       Decimal         @db.Decimal(10, 2)      // value of returned goods
  replacementTotal  Decimal         @default(0) @db.Decimal(10, 2) // value of new items (exchange)
  netRefund         Decimal         @db.Decimal(10, 2)      // returnTotal - replacementTotal; >0 paid to customer, <0 collected
  settlementMethod  ReturnSettlement                        // how net was settled: CASH or ACCOUNT_CREDIT
  note              String?
  createdByUserId   String?
  createdAt         DateTime        @default(now())
  shop              Shop            @relation(fields: [shopId], references: [id])
  originalInvoice   Invoice         @relation(fields: [originalInvoiceId], references: [id])
  customer          Customer?       @relation(fields: [customerId], references: [id])
  createdBy         User?           @relation("SaleReturnCreatedBy", fields: [createdByUserId], references: [id])
  lines             SaleReturnLine[]

  @@index([shopId, createdAt])
  @@index([originalInvoiceId])
}

model SaleReturnLine {
  id            String     @id @default(cuid())
  returnId      String
  productId     String
  quantity      Decimal    @db.Decimal(10, 3)
  unitPrice     Decimal    @db.Decimal(10, 2)
  lineTotal     Decimal    @db.Decimal(10, 2)
  isReplacement Boolean    @default(false)  // false = returned item; true = exchange new item
  restocked     Boolean    @default(true)   // false = damaged, not added back to sellable stock
  createdAt     DateTime   @default(now())
  saleReturn    SaleReturn @relation(fields: [returnId], references: [id])
  product       Product    @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([productId])
}

enum SaleReturnKind {
  REFUND
  EXCHANGE
}

enum ReturnSettlement {
  CASH
  ACCOUNT_CREDIT
}

enum InvoiceStatus {
  COMPLETED
  VOID
}

enum PaymentStatus {
  PAID
  UDHAAR
  PARTIAL  // for future
}

enum PaymentMethod {
  CASH
  CARD
  OTHER
}

model Payment {
  id          String          @id @default(cuid())
  shopId      String
  invoiceId   String?
  customerId  String?
  amount      Decimal         @db.Decimal(10, 2)
  method      PaymentMethod
  note        String?
  /// Offline client id — dedupes udhaar payments created offline so re-sync can't duplicate them.
  clientId    String?
  /// Staff member who received/recorded this payment (accountability). Null = recorded before tracking.
  receivedById String?
  /// Cash drawer (shift) this payment belongs to, if one was open when it was recorded.
  shiftId     String?
  createdAt   DateTime        @default(now())
  shop        Shop            @relation(fields: [shopId], references: [id])
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  customer    Customer?       @relation(fields: [customerId], references: [id])
  receivedBy  User?           @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  shift       Shift?          @relation(fields: [shiftId], references: [id])

  @@unique([shopId, clientId])
  @@index([shopId, createdAt])
  @@index([receivedById])
  @@index([shiftId])
}

// -----------------------------------------------------
// Expenses
// -----------------------------------------------------

model Expense {
  id          String   @id @default(cuid())
  shopId      String
  userId      String
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  description String?
  date        DateTime @default(now())
  /// Cash drawer (shift) this expense was paid from, if one was open when recorded.
  shiftId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])
  shift Shift? @relation(fields: [shiftId], references: [id])

  @@index([shopId, date])
  @@index([shiftId])
}

// -----------------------------------------------------
// Activity Log (Audit Trail)
// -----------------------------------------------------

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  orgId       String
  shopId      String?
  action      String   // CREATE_STORE, UPDATE_USER, etc.
  entityType  String   // STORE, USER, PRODUCT, SALE, etc.
  entityId    String?
  details     Json?    // Additional context (old values, new values, etc.)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now()) @db.Timestamptz // Stored in UTC/GMT
  
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  shop         Shop?        @relation(fields: [shopId], references: [id])
  
  @@index([orgId, createdAt])
  @@index([shopId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

// -----------------------------------------------------
// In-app notifications (per recipient user)
// -----------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String   // recipient
  orgId     String?  // context
  shopId    String?  // context
  type      String   // LOW_STOCK, ORG_APPROVED, ORG_SUSPENDED, etc.
  title     String
  body      String?
  href      String?  // optional in-app deep link
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

// -----------------------------------------------------
// Cash drawer / shift management
// -----------------------------------------------------
// A Shift is one cashier's cash drawer for a working period. Multiple shifts can be
// OPEN at once in the same shop (multi-cashier / multi-till); a single-counter shop is
// just the degenerate case of one open drawer. App logic enforces at most one OPEN
// shift per (shopId, openedById). Cash events (Payment / Expense / cash SupplierLedger /
// CashMovement) are stamped with the open shift of the person who handled them.
model Shift {
  id            String       @id @default(cuid())
  shopId        String
  openedById    String
  label         String?      // optional drawer/register name, e.g. "Counter 1"
  status        ShiftStatus  @default(OPEN)
  openingFloat  Decimal      @db.Decimal(10, 2)
  openedAt      DateTime     @default(now())
  closedById    String?      // who closed it (may be a manager force-closing someone else's)
  closedAt      DateTime?
  countedCash   Decimal?     @db.Decimal(10, 2) // physical cash counted at close
  expectedCash  Decimal?     @db.Decimal(10, 2) // computed expected drawer cash, snapshotted at close
  variance      Decimal?     @db.Decimal(10, 2) // countedCash - expectedCash (negative = short)
  closingNote   String?

  shop          Shop         @relation(fields: [shopId], references: [id])
  openedBy      User         @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedBy      User?        @relation("ShiftClosedBy", fields: [closedById], references: [id])
  payments      Payment[]
  expenses      Expense[]
  supplierLedger SupplierLedger[]
  movements     CashMovement[]

  @@index([shopId, status])
  @@index([openedById, status])
  @@index([shopId, openedAt])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// Manual cash added to / removed from a drawer that isn't a sale, refund, expense or
// supplier payment — e.g. owner takes cash to the bank, adds change, petty pay-out.
model CashMovement {
  id        String        @id @default(cuid())
  shopId    String
  shiftId   String
  userId    String        // who recorded it
  direction CashDir
  type      CashMoveType
  amount    Decimal       @db.Decimal(10, 2) // always positive; direction gives the sign
  reason    String?
  createdAt DateTime      @default(now())

  shop      Shop          @relation(fields: [shopId], references: [id])
  shift     Shift         @relation(fields: [shiftId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([shiftId])
  @@index([shopId, createdAt])
}

enum CashDir {
  IN
  OUT
}

enum CashMoveType {
  PAY_IN      // misc cash put into the drawer
  PAY_OUT     // misc petty cash taken out
  BANK_DROP   // cash removed to deposit at the bank
  OWNER_DRAW  // owner takes cash from the drawer
  FLOAT_ADD   // extra change/float added during the shift
  OTHER
}

